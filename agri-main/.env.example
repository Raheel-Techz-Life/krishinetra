# Frontend API Configuration
# Copy this to .env.local and update the values

# Backend API Base URL (required)
# Default: http://localhost:5000/api for development
# Production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# API Request Timeout in milliseconds
# Default: 30000 (30 seconds)
NEXT_PUBLIC_API_TIMEOUT=30000

# Optional: Bhashini AI Integration
# Uncomment if using Bhashini for multilingual voice features
# NEXT_PUBLIC_BHASHINI_API_URL=https://api.bhashini.gov.in
# NEXT_PUBLIC_BHASHINI_API_KEY=your_api_key_here

# Optional: Analytics and Monitoring
# NEXT_PUBLIC_SENTRY_DSN=https://...
# NEXT_PUBLIC_ANALYTICS_ID=

# Development flags (for local development only)
# NEXT_PUBLIC_USE_MOCK_DATA=false
